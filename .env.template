# SCIM CTL Environment Configuration Template
# Copy this file to .env and update with your values

# SCIM Server Configuration
export SCIM_CTL_TARGET="https://your-scim-server.com/scim/v2"

# OAuth 2.0 / OIDC Configuration  
export SCIM_CTL_OIDC_ISSUER="https://your-auth-server.com"
export SCIM_CTL_OIDC_CLIENT_ID="your-client-id"
export SCIM_CTL_OIDC_CLIENT_SECRET="your-client-secret"

# Optional: Enable verbose output by default
# export VERBOSE=true